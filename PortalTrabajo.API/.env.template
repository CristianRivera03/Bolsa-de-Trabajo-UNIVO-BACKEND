# =========================================================================
# PLANTILLA DE CONFIGURACIÓN DE VARIABLES DE ENTORNO (TEMPLATE)
# Copia este archivo como '.env' en este mismo directorio y completa tus credenciales.
# NO guardes ni comitas contraseñas reales en este archivo de plantilla.
# =========================================================================

# 1. Cadena de Conexión a la Base de Datos SQL Server
CONNECTIONSTRINGS__CONNECTIONDB="Data Source=TU_SERVIDOR;Initial Catalog=PortalTrabajoDB;Integrated Security=True;Trust Server Certificate=True"

# 2. Configuración de Cloudinary para carga de imágenes (Fotos de perfil y logos)
CLOUDINARYSETTINGS__CLOUDNAME="tu_cloud_name"
CLOUDINARYSETTINGS__APIKEY="tu_api_key"
CLOUDINARYSETTINGS__APISECRET="tu_api_secret"

# 3. Configuración del Token de Seguridad JWT
JWT__KEY="ColocaUnaClaveSecretaMuyLargaAquiDeAlMenos32Caracteres"
JWT__ISSUER="PortalTrabajoAPI"
JWT__AUDIENCE="PortalTrabajoFrontend"

# 4. Configuración del Servidor de Correo (SMTP)
# Para usar Gmail, debes colocar tu correo en CORREOREMITENTE
# y generar una "Contraseña de Aplicación" de 16 caracteres en la configuración de
# seguridad de tu cuenta de Google para CLAVEAPP. No uses tu contraseña personal.
CONFIGURACIONCORREO__SERVIDORSMTP="smtp.gmail.com"
CONFIGURACIONCORREO__PUERTO=587
CONFIGURACIONCORREO__CORREOREMITENTE="crisriv2003@gmail.com"
CONFIGURACIONCORREO__CLAVEAPP="ntfw xrbb pesu idfb"
CONFIGURACIONCORREO__NOMBREREMITENTE="Bolsa de Trabajo UNIVO"
